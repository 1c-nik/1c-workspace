{
  // --- Терминал: Git Bash по умолчанию ---
  "terminal.integrated.defaultProfile.windows": "Git Bash",
  "terminal.integrated.profiles.windows": {
    "Git Bash": {
      "path": "C:\\Program Files\\Git\\bin\\bash.exe"
    },
    "PowerShell": { "source": "PowerShell" },
    "Command Prompt": { "path": "C:\\Windows\\System32\\cmd.exe" }
  },

  // --- Глушим чужих AI-агентов в этом workspace ---
  "github.copilot.enable": { "*": false },
  "github.copilot.editor.enableAutoCompletions": false,
  "editor.inlineSuggest.enabled": false,

  // --- Не индексировать выгрузку конфигурации (тысячи файлов) ---
  "search.exclude": {
    "**/mainConf": true,
    "**/node_modules": true,
    "**/.git": true
  },
  "files.watcherExclude": {
    "**/mainConf/**": true
  },

  // --- Сохранение и форматирование (без дёрганья при печати) ---
  "files.autoSave": "onFocusChange",
  "editor.formatOnSave": false,

  // --- BSL ---
  "[bsl]": {
    "editor.defaultFormatter": "1c-syntax.language-1c-bsl"
  },
  "language-1c-bsl.languageServerEnabled": true
}